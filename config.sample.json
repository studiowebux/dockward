{
  "runtime": "docker",
  "registry": {
    "url": "http://localhost:5000",
    "poll_interval": 300,
    "insecure": false
  },
  "api": {
    "address": ["127.0.0.1:9090"]
  },
  "monitor": {
    "stats_interval": 30
  },
  "docker_health": {
    "check_interval": 30,
    "timeout": 5
  },
  "audit": {
    "path": "/var/log/dockward/audit.jsonl"
  },
  "push": {
    "warden_url": "",
    "token": "$DOCKWARD_PUSH_TOKEN",
    "machine_id": "ovh-01"
  },
  "notifications": {
    "discord": {
      "webhook_url": "https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"
    },
    "smtp": {
      "host": "smtp.example.com",
      "port": 587,
      "from": "alerts@webux.dev",
      "to": "tommy@studiowebux.com",
      "username": "",
      "password": ""
    },
    "webhooks": [
      {
        "name": "github-deploy-pipeline",
        "url": "https://api.github.com/repos/studiowebux/infrastructure/actions/workflows/deploy.yml/dispatches",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer $GH_TOKEN",
          "Accept": "application/vnd.github.v3+json"
        },
        "body": "{\"ref\":\"main\",\"inputs\":{\"service\":\"{{ .Service }}\",\"event\":\"{{ .Event }}\"}}"
      }
    ]
  },
  "services": [
    {
      "name": "myapp",
      "images": ["myapp:latest"],
      "silent": false,
      "compose_files": [
        "/srv/myapp/docker-compose.yml"
      ],
      "compose_project": "myapp",
      "env_file": "/srv/myapp/.env",
      "auto_update": true,
      "auto_start": true,
      "auto_heal": true,
      "compose_watch": false,
      "health_grace": 60,
      "heal_cooldown": 300,
      "heal_max_restarts": 3,
      "cpu_threshold": 80,
      "memory_threshold": 85
    },
    {
      "name": "myapp-multi",
      "images": ["api:latest", "worker:latest"],
      "compose_files": [
        "/srv/myapp/docker-compose.yml",
        "/srv/myapp/docker-compose.override.yml"
      ],
      "compose_project": "myapp",
      "auto_update": true,
      "auto_heal": true,
      "health_grace": 60,
      "heal_cooldown": 300
    },
    {
      "name": "proxy",
      "compose_files": [
        "/srv/proxy/docker-compose.yml"
      ],
      "compose_project": "proxy",
      "auto_update": false,
      "auto_heal": true,
      "compose_watch": true,
      "health_grace": 60,
      "heal_cooldown": 300
    },
    {
      "name": "standalone-api",
      "container_name": "standalone-api",
      "auto_heal": true,
      "heal_cooldown": 120,
      "heal_max_restarts": 5
    }
  ]
}
